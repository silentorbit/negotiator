{
  "compileOnSave": true,
  "compilerOptions": {
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": false,
    "outDir": "extension/script",

    /* Language and Environment */
    "target": "ESNext",
    "lib": [ "ESNext", "DOM", "DOM.Iterable" ],

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "TypeScript/*.ts",
    "TypeScript/**/*.ts"
  ]
}